---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FaqSection from '../components/FaqSection.astro';
import CtaBanner from '../components/CtaBanner.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Plombier Rillieux-la-Pape', url: '/plombier-rillieux-la-pape/' },
];

const jsonLd = [
  {
    '@type': 'LocalBusiness',
    '@id': 'https://rm-plombier.fr/plombier-rillieux-la-pape/#business',
    name: 'RM Plombier SARL - Plombier Rillieux-la-Pape',
    url: 'https://rm-plombier.fr/plombier-rillieux-la-pape/',
    telephone: '+33635464924',
    description: 'Plombier à Rillieux-la-Pape : urgence, chauffage, climatisation, rénovation. Note 5/5 Google. Devis gratuit.',
    address: { '@type': 'PostalAddress', addressLocality: 'Neyron', postalCode: '01700', addressRegion: 'Ain', addressCountry: 'FR' },
    areaServed: { '@type': 'City', name: 'Rillieux-la-Pape' },
    priceRange: '€€',
  },
  {
    '@type': 'Service',
    '@id': 'https://rm-plombier.fr/plombier-rillieux-la-pape/#service',
    name: 'Plombier à Rillieux-la-Pape',
    provider: { '@id': 'https://rm-plombier.fr/plombier-rillieux-la-pape/#business' },
    areaServed: { '@type': 'City', name: 'Rillieux-la-Pape' },
    description: 'Climatisation, détection de fuites et dépannage plomberie à Rillieux-la-Pape (69140).',
  },
  {
    '@type': 'BreadcrumbList',
    '@id': 'https://rm-plombier.fr/plombier-rillieux-la-pape/#breadcrumb',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://rm-plombier.fr/' },
      { '@type': 'ListItem', position: 2, name: 'Plombier Rillieux-la-Pape', item: 'https://rm-plombier.fr/plombier-rillieux-la-pape/' },
    ],
  },
];

const services = [
  { title: 'Climatisation et pompe à chaleur', description: 'Installation de climatisation réversible et PAC air-eau, adaptée aux maisons et appartements de Rillieux.', href: '/services/climatisation-pompe-a-chaleur/', icon: 'snowflake', tags: ['Clim réversible', 'PAC air-eau'] },
  { title: 'Détection et réparation de fuites', description: 'Recherche de fuites non destructive, idéale pour les copropriétés où les dégâts des eaux sont fréquents.', href: '/services/detection-reparation-fuites/', icon: 'search', tags: ['Non destructif', 'Copropriété'] },
  { title: 'Dépannage plomberie urgence', description: 'Intervention rapide 7j/7, y compris débouchage de canalisations.', href: '/services/depannage-plomberie/', icon: 'wrench', tags: ['Fuite d\'eau', 'Débouchage', '7j/7'] },
];

const faq = [
  { q: 'Intervenez-vous en copropriété à Rillieux-la-Pape ?', a: 'Oui, nous intervenons régulièrement dans les résidences collectives de Rillieux pour des problèmes de fuites, de canalisations bouchées ou de remplacement de robinetterie. Nous travaillons en lien avec les syndics si nécessaire.' },
  { q: 'Pouvez-vous installer une climatisation dans un appartement à Rillieux ?', a: 'Oui, sous réserve de l\'accord de la copropriété pour l\'unité extérieure. Nous vous conseillons sur le modèle adapté et nous occupons du dossier technique.' },
  { q: 'Quels sont vos tarifs pour un dépannage à Rillieux-la-Pape ?', a: 'Nos tarifs dépendent de la nature de l\'intervention. Le déplacement est inclus, et nous communiquons systématiquement le prix avant de commencer les travaux. Pas de mauvaise surprise.' },
  { q: 'Acceptez-vous les demandes de devis pour les particuliers comme pour les professionnels ?', a: 'Oui, nous travaillons aussi bien avec des particuliers qu\'avec des professionnels (commerces, restaurants, bureaux) à Rillieux-la-Pape et dans la métropole.' },
];
---

<Base
  title="Plombier Rillieux-la-Pape (69140) | RM Plombier SARL"
  description="Plombier à Rillieux-la-Pape : urgence, chauffage, climatisation, rénovation. Note 5/5 Google. Devis gratuit. Contactez-nous au 06 35 46 49 24."
  canonical="https://rm-plombier.fr/plombier-rillieux-la-pape/"
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>

  <!-- HERO -->
  <section class="py-20 lg:py-28 bg-gradient-to-br from-primary-dark to-primary relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]">
      <svg width="100%" height="100%"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
    </div>
    <div class="max-w-6xl mx-auto px-4 lg:px-6 relative z-10">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 mb-6 backdrop-blur-sm">
        <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span class="text-sm font-medium text-white/90">Rillieux-la-Pape (69140) . à 5 km de Neyron</span>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight text-white mb-4 max-w-3xl">
        Plombier à Rillieux-la-Pape, dépannage et installation dans le <span class="text-accent">Rhône</span>
      </h1>
      <p class="text-lg text-white/70 mb-8 leading-relaxed max-w-2xl">
        RM Plombier SARL intervient à Rillieux-la-Pape pour tous vos travaux de plomberie, chauffage et climatisation. Depuis notre siège de Neyron, nous rejoignons Rillieux en 15 minutes par la D84, ce qui nous permet d'être réactifs y compris pour les urgences.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="tel:0635464924" class="btn-accent text-base py-4 px-8">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Appeler maintenant
        </a>
        <a href="/contact/" class="btn-ghost text-base py-4 px-8">
          Devis gratuit en ligne
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 overflow-hidden -mb-px" style="line-height:0"><svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-[40px] sm:h-[50px] lg:h-[60px]"><polygon points="0,60 1440,20 1440,60" fill="#F8FAFC"/></svg></div>
  </section>

  <!-- INTRODUCTION -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-3xl mx-auto px-4 lg:px-6 reveal">
      <p class="text-slate-600 leading-relaxed mb-6">
        Avec plus de 31 000 habitants, Rillieux-la-Pape est l'une des plus grandes communes du nord de la métropole de Lyon. La ville compte une forte proportion de logements collectifs, notamment dans les quartiers de la Velette, des Alagniers et de Semailles. Ces immeubles, souvent construits dans les années 60-70, nécessitent des interventions régulières : remplacement de colonnes montantes, mise aux normes des installations de gaz, rénovation de salles de bain datées.
      </p>
      <p class="text-slate-600 leading-relaxed">
        Mais Rillieux, c'est aussi des quartiers pavillonnaires en pleine évolution du côté de Crépieux et de Mont-Blanc, où les demandes portent davantage sur l'installation de pompes à chaleur, la climatisation réversible et les projets de rénovation énergétique. Quelle que soit la nature de votre besoin, nos techniciens s'adaptent au contexte du logement. Appelez le 06 35 46 49 24 pour un devis gratuit.
      </p>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 lg:px-6">
      <div class="text-center mb-12 reveal">
        <span class="section-label">Nos interventions</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Services disponibles à Rillieux-la-Pape</h2>
        <p class="text-slate-500 max-w-xl mx-auto">Nos équipes réalisent toutes les prestations de plomberie et chauffage à Rillieux.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
        {services.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- PROXIMITÉ -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-3xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-8">
        <span class="section-label">Proximité</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900">Votre plombier à 15 minutes de Rillieux-la-Pape</h2>
      </div>
      <p class="text-slate-600 leading-relaxed text-center">
        Neyron et Rillieux-la-Pape sont séparées par seulement 5 km. Que vous soyez dans le centre de Rillieux, vers Crépieux-la-Pape ou dans le secteur des Allagniers, notre équipe vous rejoint rapidement. Cette proximité facilite aussi le suivi de chantier pour les projets plus importants comme une rénovation complète ou une installation de chauffage.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <FaqSection questions={faq} title="Questions fréquentes - Rillieux-la-Pape" />

  <!-- CTA -->
  <CtaBanner title="Besoin d'un plombier à Rillieux-la-Pape ?" subtitle="Devis gratuit, intervention rapide depuis Neyron." />

</Base>
