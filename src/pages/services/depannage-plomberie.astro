---
import Base from '../../layouts/Base.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Services', url: '/#services' },
  { name: 'Dépannage plomberie', url: '/services/depannage-plomberie/' },
];

const jsonLd = [
  {
    '@type': 'Service',
    '@id': 'https://rm-plombier.fr/services/depannage-plomberie/#service',
    name: 'Dépannage plomberie urgence',
    description: 'Dépannage plomberie en urgence dans l\'Ain et le Rhône. Fuite, WC bouché, panne chauffe-eau. Intervention rapide 7j/7.',
    provider: { '@type': 'Plumber', '@id': 'https://rm-plombier.fr/#business' },
    areaServed: [
      { '@type': 'City', name: 'Neyron' },
      { '@type': 'City', name: 'Miribel' },
      { '@type': 'City', name: 'Rillieux-la-Pape' },
      { '@type': 'City', name: 'Beynost' },
      { '@type': 'City', name: 'Montluel' },
      { '@type': 'City', name: 'Caluire-et-Cuire' },
    ],
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: crumb.name,
      item: `https://rm-plombier.fr${crumb.url}`,
    })),
  },
];

const prestations = [
  'Recherche et réparation de fuites d\'eau (apparentes et encastrées)',
  'Débouchage de canalisations, WC et évacuations',
  'Remplacement de robinetterie et mécanismes de chasse d\'eau',
  'Dépannage et remplacement de chauffe-eau (électrique et gaz)',
  'Réparation de canalisations percées ou fissurées',
  'Remplacement de joints, flexibles et raccords',
  'Remise en pression du réseau d\'eau',
  'Rapport d\'intervention pour assurance (dégât des eaux)',
];

const etapes = [
  { title: 'Appel et diagnostic téléphonique', desc: 'Vous décrivez la situation, nous vous guidons sur les gestes d\'urgence et estimons le délai d\'arrivée.' },
  { title: 'Arrivée sur place et diagnostic', desc: 'Notre technicien examine l\'installation, identifie la cause du problème et vous communique le tarif de l\'intervention.' },
  { title: 'Validation et réparation', desc: 'Après votre accord, nous procédons à la réparation avec le matériel embarqué dans notre véhicule.' },
  { title: 'Test et vérification', desc: 'Nous testons l\'installation réparée pour nous assurer que tout fonctionne correctement.' },
  { title: 'Compte-rendu et conseils', desc: 'Nous vous expliquons ce qui a été fait et vous donnons des recommandations pour éviter la récidive.' },
];

const communes = [
  { label: 'Dépannage plomberie à Miribel', href: '/plombier-miribel/', detail: '10 min de trajet' },
  { label: 'Dépannage plomberie à Rillieux-la-Pape', href: '/plombier-rillieux-la-pape/', detail: '15 min de trajet' },
  { label: 'Dépannage plomberie à Beynost', href: '/plombier-beynost/', detail: '12 min de trajet' },
  { label: 'Dépannage plomberie à Montluel', href: '/plombier-montluel/', detail: '20 min de trajet' },
  { label: 'Dépannage plomberie à Caluire-et-Cuire', href: '/plombier-caluire-et-cuire/', detail: '15 min de trajet' },
];

const faq = [
  { q: 'Combien coûte un dépannage plomberie d\'urgence ?', a: 'Le tarif dépend de la nature de l\'intervention. Le déplacement est inclus dans notre zone (Ain et nord Rhône). Nous vous communiquons le prix exact avant de commencer, sans engagement.' },
  { q: 'Intervenez-vous la nuit ?', a: 'Nous intervenons en journée étendue (7h-21h) et le week-end. Pour les urgences en soirée, appelez le 06 35 46 49 24, nous évaluons la situation et intervenons si possible ou dès le lendemain matin.' },
  { q: 'Avez-vous les pièces sur place pour réparer immédiatement ?', a: 'Notre véhicule est équipé des pièces les plus courantes : joints, flexibles, raccords, robinets, mécanismes de chasse. Pour les pièces spécifiques, nous pouvons commander et repasser rapidement.' },
  { q: 'Fournissez-vous une facture pour l\'assurance ?', a: 'Oui, nous établissons systématiquement une facture détaillée. En cas de dégât des eaux, nous pouvons aussi rédiger un rapport d\'intervention pour votre dossier d\'assurance.' },
];
---

<Base
  title="Dépannage plomberie urgence 7j/7 | RM Plombier SARL"
  description="Dépannage plomberie en urgence dans l'Ain et le Rhône. Fuite, WC bouché, panne chauffe-eau. Intervention rapide 7j/7. Appelez le 06 35 46 49 24."
  canonical="https://rm-plombier.fr/services/depannage-plomberie/"
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>

  <!-- HERO COMPACT -->
  <section class="py-16 lg:py-20 bg-gradient-to-br from-primary-dark via-primary to-primary-light relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]">
      <svg width="100%" height="100%"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
    </div>
    <div class="max-w-6xl mx-auto px-4 lg:px-6 relative z-10">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 mb-6 backdrop-blur-sm">
          <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
          <span class="text-sm font-medium text-white/90">Urgence 7j/7, intervention rapide</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight tracking-tight text-white mb-4">
          Dépannage plomberie urgence à Neyron et dans <span class="text-accent">l'Ain</span>
        </h1>
        <p class="text-lg text-white/70 mb-8 leading-relaxed max-w-2xl">
          Fuite d'eau, WC bouché, chauffe-eau en panne. RM Plombier SARL intervient en urgence 7 jours sur 7 dans l'Ain et le Rhône.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="tel:0635464924" class="btn-accent text-base py-4 px-8">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Appelez le 06 35 46 49 24
          </a>
          <a href="/contact/" class="btn-ghost text-base py-4 px-8">
            Obtenir un devis
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0"><svg viewBox="0 0 1440 60" fill="none"><path d="M0 60H1440V30C1200 0 960 60 720 30C480 0 240 60 0 30V60Z" fill="#F8FAFC"/></svg></div>
  </section>

  <!-- DESCRIPTION DÉTAILLÉE -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 lg:px-6 reveal">
      <span class="section-label">Présentation du service</span>
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mt-2 mb-8">Votre plombier d'urgence dans l'Ain et le Rhône</h2>
      <div class="prose prose-slate max-w-none space-y-4 text-slate-600 leading-relaxed">
        <p>Une fuite d'eau qui s'aggrave, un WC bouché un dimanche matin, un chauffe-eau qui lâche en plein hiver. Ces situations ne préviennent pas, et c'est pour cela que RM Plombier SARL assure un service de dépannage plomberie 7 jours sur 7, jours fériés compris.</p>
        <p>Depuis notre base de Neyron, nous couvrons l'ensemble du nord de l'agglomération lyonnaise. Notre temps d'intervention moyen est de 30 à 45 minutes selon votre localisation. Dès votre appel, nous évaluons la situation par téléphone et vous donnons les premiers conseils pour limiter les dégâts en attendant notre arrivée : couper l'arrivée d'eau, isoler le circuit concerné, protéger vos biens.</p>
        <p>Sur place, notre technicien réalise un diagnostic complet avant toute intervention. Le prix est communiqué clairement, vous décidez en connaissance de cause. Pas de travaux imposés, pas de facturation surprise. C'est ce principe de transparence qui nous a permis d'obtenir une note de 5/5 sur Google avec 54 avis vérifiés.</p>
        <p>Nos dépannages les plus fréquents concernent les fuites sur raccords et canalisations, les débouchages de WC et de canalisations d'évacuation, les pannes de chauffe-eau (électrique et gaz), les robinets défectueux et les problèmes de pression d'eau. Nous intervenons sur tous types d'installations, du réseau en cuivre ancien aux installations en PER des constructions récentes.</p>
        <p>En cas de dégât des eaux, nous pouvons également établir un rapport d'intervention qui facilitera vos démarches auprès de votre assurance. Notre objectif est de résoudre votre problème rapidement tout en vous accompagnant sur les aspects administratifs si besoin.</p>
        <p>Pour les pannes récurrentes, nous ne nous contentons pas de traiter le symptôme. Nous identifions la cause profonde et vous proposons, si nécessaire, une remise en état durable pour éviter que le problème ne se reproduise. Un dépannage peut ainsi déboucher sur un devis de remplacement si l'équipement est en fin de vie.</p>
        <p class="font-semibold text-slate-900">Vous avez une urgence plomberie ? Appelez le 06 35 46 49 24, nous vous répondons immédiatement et organisons l'intervention dans les meilleurs délais.</p>
      </div>
    </div>
  </section>

  <!-- PRESTATIONS INCLUSES -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-12">
        <span class="section-label">Ce que nous faisons</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Prestations incluses</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {prestations.map(p => (
          <div class="flex items-start gap-3 bg-surface rounded-xl p-5 border border-slate-100">
            <div class="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-slate-700 text-sm lg:text-base leading-relaxed">{p}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ÉTAPES D'INTERVENTION -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-12">
        <span class="section-label">Notre méthode</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Étapes d'intervention</h2>
      </div>
      <div class="relative">
        <div class="absolute left-6 lg:left-8 top-0 bottom-0 w-0.5 bg-primary/20 hidden sm:block"></div>
        <div class="space-y-6">
          {etapes.map((e, i) => (
            <div class="flex gap-4 lg:gap-6 items-start relative">
              <div class="w-12 h-12 lg:w-16 lg:h-16 bg-primary rounded-2xl flex items-center justify-center flex-shrink-0 relative z-10 shadow-lg shadow-primary/20">
                <span class="text-white font-extrabold text-lg lg:text-xl">{i + 1}</span>
              </div>
              <div class="bg-white rounded-xl p-5 lg:p-6 border border-slate-100 flex-1 shadow-sm">
                <h3 class="font-bold text-slate-900 mb-2 text-base lg:text-lg">{e.title}</h3>
                <p class="text-slate-500 text-sm lg:text-base leading-relaxed">{e.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- COMMUNES DESSERVIES -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-12">
        <span class="section-label">Zone d'intervention</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Communes desservies</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {communes.map(c => (
          <a href={c.href} class="card group py-6 px-5 flex items-center gap-4">
            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div class="font-bold text-slate-900 text-sm group-hover:text-primary transition-colors">{c.label}</div>
              <div class="text-xs text-slate-400">{c.detail}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FaqSection questions={faq} title="Questions sur le dépannage plomberie" />

  <!-- CTA -->
  <CtaBanner title="Une urgence plomberie ?" subtitle="Intervention rapide 7j/7 dans l'Ain et le Rhône. Devis gratuit." />

</Base>
