---
import Base from '../../layouts/Base.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaBanner from '../../components/CtaBanner.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Services', url: '/#services' },
  { name: 'Climatisation et PAC', url: '/services/climatisation-pompe-a-chaleur/' },
];

const jsonLd = [
  {
    '@type': 'Service',
    '@id': 'https://rm-plombier.fr/services/climatisation-pompe-a-chaleur/#service',
    name: 'Climatisation et pompe à chaleur',
    description: 'Installation de climatisation réversible et pompe à chaleur à Neyron et dans l\'Ain. Confort été comme hiver. Devis gratuit.',
    provider: { '@type': 'Plumber', '@id': 'https://rm-plombier.fr/#business' },
    areaServed: [
      { '@type': 'City', name: 'Neyron' },
      { '@type': 'City', name: 'Miribel' },
      { '@type': 'City', name: 'Rillieux-la-Pape' },
      { '@type': 'City', name: 'Beynost' },
      { '@type': 'City', name: 'Montluel' },
      { '@type': 'City', name: 'Caluire-et-Cuire' },
    ],
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: crumb.name,
      item: `https://rm-plombier.fr${crumb.url}`,
    })),
  },
];

const prestations = [
  'Étude thermique et dimensionnement gratuit',
  'Fourniture et pose de climatisation réversible (mono et multi-split)',
  'Installation de pompe à chaleur air-eau',
  'Raccordement au circuit de chauffage existant (pour PAC)',
  'Mise en service et programmation',
  'Entretien et maintenance annuelle',
  'Dépannage climatisation (panne, recharge gaz)',
  'Conseil sur les aides financières',
];

const etapes = [
  { title: 'Étude à domicile', desc: 'Nous visitons votre logement, évaluons le volume à climatiser ou chauffer, et identifions l\'emplacement optimal des unités.' },
  { title: 'Proposition technique et devis', desc: 'Nous vous présentons la solution retenue avec le détail des coûts, la consommation estimée et les aides mobilisables.' },
  { title: 'Installation', desc: 'Pose des unités intérieure et extérieure, tirage des liaisons frigorifiques, raccordement électrique. Durée : 1 jour pour un mono-split, 2 jours pour un multi-split ou une PAC.' },
  { title: 'Mise en service', desc: 'Charge en fluide frigorigène, tests de fonctionnement, réglage des paramètres de confort.' },
  { title: 'Prise en main', desc: 'Nous vous expliquons le fonctionnement de la télécommande, les modes disponibles et les réflexes d\'entretien courant (nettoyage des filtres).' },
];

const communes = [
  { label: 'Climatisation à Miribel', href: '/plombier-miribel/', detail: 'Maisons et appartements' },
  { label: 'Pompe à chaleur à Rillieux-la-Pape', href: '/plombier-rillieux-la-pape/', detail: 'Pavillons et copropriétés' },
  { label: 'Installation climatisation à Beynost', href: '/plombier-beynost/', detail: 'Constructions neuves et existantes' },
  { label: 'Climatisation à Montluel', href: '/plombier-montluel/', detail: 'Logements individuels' },
  { label: 'Pompe à chaleur à Caluire-et-Cuire', href: '/plombier-caluire-et-cuire/', detail: 'Rénovation énergétique' },
];

const faq = [
  { q: 'Quelle différence entre climatisation et pompe à chaleur ?', a: 'La climatisation réversible (split) traite l\'air directement. La pompe à chaleur air-eau chauffe l\'eau d\'un circuit de radiateurs ou de plancher chauffant. Les deux peuvent rafraîchir et chauffer, mais la PAC est plus adaptée comme chauffage principal d\'une maison.' },
  { q: 'Quel est le niveau sonore d\'une climatisation ?', a: 'Les unités intérieures modernes fonctionnent autour de 20-25 dB en mode silence, soit moins qu\'un murmure. L\'unité extérieure émet environ 45-50 dB. Nous veillons à son positionnement pour limiter les nuisances.' },
  { q: 'Faut-il l\'accord de la copropriété pour installer une clim ?', a: 'Oui, l\'installation d\'une unité extérieure en copropriété nécessite un vote en assemblée générale. Nous fournissons le dossier technique nécessaire pour appuyer votre demande.' },
  { q: 'Quel budget pour une climatisation réversible ?', a: 'Pour un mono-split (une pièce), comptez entre 1 500 et 2 500 euros pose comprise. Pour un multi-split (3-4 pièces), le budget se situe entre 4 000 et 7 000 euros selon la puissance et le nombre d\'unités.' },
];
---

<Base
  title="Climatisation et pompe à chaleur Ain | RM Plombier SARL"
  description="Installation de climatisation réversible et pompe à chaleur à Neyron et dans l'Ain. Confort été comme hiver. Devis gratuit au 06 35 46 49 24."
  canonical="https://rm-plombier.fr/services/climatisation-pompe-a-chaleur/"
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>

  <!-- HERO COMPACT -->
  <section class="py-16 lg:py-20 bg-gradient-to-br from-primary-dark via-primary to-primary-light relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]">
      <svg width="100%" height="100%"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
    </div>
    <div class="max-w-6xl mx-auto px-4 lg:px-6 relative z-10">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 mb-6 backdrop-blur-sm">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/></svg>
            <span class="text-sm font-medium text-white/90">Confort été comme hiver</span>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight tracking-tight text-white mb-4">
            Climatisation et pompe à chaleur à Neyron et dans <span class="text-accent">l'Ain</span>
          </h1>
          <p class="text-lg text-white/70 mb-8 leading-relaxed max-w-2xl">
            Climatisations réversibles et pompes à chaleur air-eau adaptées aux maisons et appartements de la région. Étude gratuite à domicile.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="tel:0635464924" class="btn-accent text-base py-4 px-8">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Appelez le 06 35 46 49 24
            </a>
            <a href="/contact/" class="btn-ghost text-base py-4 px-8">
              Obtenir un devis
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src="https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/pac-buanderie-gris-landscape.png"
            alt="Pompe à chaleur installée dans une buanderie"
            class="rounded-2xl shadow-2xl w-full aspect-[4/3] object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 overflow-hidden -mb-px" style="line-height:0"><svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-[40px] sm:h-[50px] lg:h-[60px]"><polygon points="0,60 1440,20 1440,60" fill="#F8FAFC"/></svg></div>
  </section>

  <!-- DESCRIPTION DÉTAILLÉE -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 lg:px-6 reveal">
      <span class="section-label">Présentation du service</span>
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mt-2 mb-8">Climatisation et PAC pour votre confort toute l'année</h2>
      <div class="mb-8 rounded-2xl overflow-hidden shadow-md">
        <img src="https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/thermodynamique-cellier-square.png" alt="Chauffe-eau thermodynamique installé dans un cellier" class="w-full aspect-[21/9] object-cover" loading="lazy" />
      </div>
      <div class="prose prose-slate max-w-none space-y-4 text-slate-600 leading-relaxed">
        <p>Les étés sont de plus en plus chauds dans la région lyonnaise, et le confort thermique est devenu un critère essentiel dans l'habitat. RM Plombier SARL installe des solutions de climatisation et de pompe à chaleur adaptées aux logements de l'Ain et du nord du Rhône.</p>
        <p>La climatisation réversible est aujourd'hui la solution la plus demandée. Elle rafraîchit votre intérieur en été et le chauffe en hiver grâce à un système thermodynamique performant. Un seul équipement remplace ainsi un chauffage d'appoint et un ventilateur, avec une consommation électrique maîtrisée. Nous installons des systèmes mono-split (une pièce) et multi-split (plusieurs pièces) des marques les plus fiables du marché.</p>
        <p>Pour les maisons individuelles, la pompe à chaleur air-eau constitue une alternative au chauffage gaz ou fioul. Elle capte les calories présentes dans l'air extérieur pour chauffer l'eau de votre circuit de radiateurs ou de plancher chauffant. Son rendement est particulièrement intéressant dans notre climat : pour 1 kWh d'électricité consommée, elle produit en moyenne 3 à 4 kWh de chaleur.</p>
        <p>L'installation d'une climatisation ou d'une pompe à chaleur nécessite une étude préalable sérieuse. Nous dimensionnons le système en fonction du volume à traiter, de l'exposition du logement, du niveau d'isolation et de vos habitudes de vie. Un équipement surdimensionné consommera trop, un équipement sous-dimensionné ne sera pas efficace. Notre rôle est de trouver le juste calibrage.</p>
        <p>En copropriété, l'installation d'une climatisation implique des contraintes spécifiques : accord de la copropriété pour l'unité extérieure, respect des règles de bruit, positionnement esthétique. Nous vous accompagnons dans la constitution du dossier et proposons des solutions discrètes qui respectent les exigences des syndics.</p>
        <p>Les aides financières s'appliquent aussi aux pompes à chaleur : MaPrimeRénov', CEE, TVA réduite. Nous intégrons ces éléments dans notre proposition pour vous donner une vision claire du reste à charge.</p>
        <p class="font-semibold text-slate-900">Appelez le 06 35 46 49 24 pour une étude gratuite à domicile.</p>
      </div>
    </div>
  </section>

  <!-- PRESTATIONS INCLUSES -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-12">
        <span class="section-label">Ce que nous faisons</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Prestations incluses</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {prestations.map(p => (
          <div class="flex items-start gap-3 bg-surface rounded-xl p-5 border border-slate-100">
            <div class="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-slate-700 text-sm lg:text-base leading-relaxed">{p}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ÉTAPES D'INTERVENTION -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-12">
        <span class="section-label">Notre méthode</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Étapes d'intervention</h2>
      </div>
      <div class="relative">
        <div class="absolute left-6 lg:left-8 top-0 bottom-0 w-0.5 bg-primary/20 hidden sm:block"></div>
        <div class="space-y-6">
          {etapes.map((e, i) => (
            <div class="flex gap-4 lg:gap-6 items-start relative">
              <div class="w-12 h-12 lg:w-16 lg:h-16 bg-primary rounded-2xl flex items-center justify-center flex-shrink-0 relative z-10 shadow-lg shadow-primary/20">
                <span class="text-white font-extrabold text-lg lg:text-xl">{i + 1}</span>
              </div>
              <div class="bg-white rounded-xl p-5 lg:p-6 border border-slate-100 flex-1 shadow-sm">
                <h3 class="font-bold text-slate-900 mb-2 text-base lg:text-lg">{e.title}</h3>
                <p class="text-slate-500 text-sm lg:text-base leading-relaxed">{e.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- COMMUNES DESSERVIES -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-12">
        <span class="section-label">Zone d'intervention</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Communes desservies</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {communes.map(c => (
          <a href={c.href} class="card group py-6 px-5 flex items-center gap-4">
            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div class="font-bold text-slate-900 text-sm group-hover:text-primary transition-colors">{c.label}</div>
              <div class="text-xs text-slate-400">{c.detail}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FaqSection questions={faq} title="Questions sur la climatisation et PAC" />

  <!-- CTA -->
  <CtaBanner title="Un projet de climatisation ?" subtitle="Étude thermique gratuite à domicile, devis détaillé avec aides." />

</Base>
