---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FaqSection from '../components/FaqSection.astro';
import CtaBanner from '../components/CtaBanner.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Plombier Montluel', url: '/plombier-montluel/' },
];

const jsonLd = [
  {
    '@type': 'LocalBusiness',
    '@id': 'https://rm-plombier.fr/plombier-montluel/#business',
    name: 'RM Plombier SARL - Plombier Montluel',
    url: 'https://rm-plombier.fr/plombier-montluel/',
    telephone: '+33635464924',
    description: 'Plombier à Montluel et dans la Côtière : dépannage 7j/7, chauffage, rénovation. Artisan noté 5/5 sur Google. Devis gratuit.',
    address: { '@type': 'PostalAddress', addressLocality: 'Neyron', postalCode: '01700', addressRegion: 'Ain', addressCountry: 'FR' },
    areaServed: { '@type': 'City', name: 'Montluel' },
    priceRange: '€€',
  },
  {
    '@type': 'Service',
    '@id': 'https://rm-plombier.fr/plombier-montluel/#service',
    name: 'Plombier à Montluel',
    provider: { '@id': 'https://rm-plombier.fr/plombier-montluel/#business' },
    areaServed: { '@type': 'City', name: 'Montluel' },
    description: 'Détection de fuites, dépannage plomberie et installation chaudière à Montluel (01120).',
  },
  {
    '@type': 'BreadcrumbList',
    '@id': 'https://rm-plombier.fr/plombier-montluel/#breadcrumb',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://rm-plombier.fr/' },
      { '@type': 'ListItem', position: 2, name: 'Plombier Montluel', item: 'https://rm-plombier.fr/plombier-montluel/' },
    ],
  },
];

const services = [
  { title: 'Détection et réparation de fuites', description: 'Recherche de fuites par méthodes non destructives, indispensable dans les bâtiments anciens du centre de Montluel.', href: '/services/detection-reparation-fuites/', icon: 'search', tags: ['Non destructif', 'Bâti ancien'] },
  { title: 'Dépannage plomberie urgence', description: 'Débouchage canalisation, panne de chauffe-eau, fuite sur raccord. Intervention 7j/7.', href: '/services/depannage-plomberie/', icon: 'wrench', tags: ['Débouchage', 'Chauffe-eau', '7j/7'] },
  { title: 'Installation et remplacement de chaudière', description: 'Passage d\'une chaudière classique à un modèle performant, avec aide aux démarches pour les primes énergie.', href: '/services/installation-chaudiere/', icon: 'fire', tags: ['Condensation', 'Primes énergie'] },
];

const faq = [
  { q: 'Intervenez-vous dans les vieilles maisons du centre de Montluel ?', a: 'Oui, c\'est même une spécificité de nos interventions à Montluel. Nous savons travailler sur des réseaux anciens, repérer les canalisations problématiques et proposer des solutions durables sans tout casser.' },
  { q: 'Pouvez-vous remplacer une chaudière fioul à Montluel ?', a: 'Oui, nous assurons le remplacement de chaudières fioul par des alternatives plus économiques et écologiques : chaudière gaz condensation ou pompe à chaleur. Nous vous aidons à identifier les aides disponibles (MaPrimeRénov\', CEE).' },
  { q: 'Quelle est votre zone autour de Montluel ?', a: 'Nous intervenons à Montluel et dans toutes les communes de la Côtière : Dagneux, Balan, Bressolles, Pizay, Nievroz. Le devis et le déplacement sont gratuits sur ce secteur.' },
  { q: 'Faites-vous du dépannage le dimanche à Montluel ?', a: 'Oui, notre service d\'urgence fonctionne 7 jours sur 7, dimanche et jours fériés compris. Appelez le 06 35 46 49 24, nous vous indiquons notre disponibilité immédiate.' },
];
---

<Base
  title="Plombier Montluel (01120) | RM Plombier SARL - Ain"
  description="Plombier à Montluel et dans la Côtière : dépannage 7j/7, chauffage, rénovation. Artisan noté 5/5 sur Google. Devis gratuit au 06 35 46 49 24."
  canonical="https://rm-plombier.fr/plombier-montluel/"
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>

  <!-- HERO -->
  <section class="py-20 lg:py-28 bg-gradient-to-br from-primary-dark to-primary relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]">
      <svg width="100%" height="100%"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
    </div>
    <div class="max-w-6xl mx-auto px-4 lg:px-6 relative z-10">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 mb-6 backdrop-blur-sm">
        <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span class="text-sm font-medium text-white/90">Montluel (01120) . à 12 km de Neyron</span>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight text-white mb-4 max-w-3xl">
        Plombier à Montluel, artisan de confiance dans la <span class="text-accent">Côtière</span>
      </h1>
      <p class="text-lg text-white/70 mb-8 leading-relaxed max-w-2xl">
        RM Plombier SARL assure des prestations de plomberie, chauffage et climatisation à Montluel et dans les communes environnantes de la Côtière. Depuis Neyron, nous rejoignons Montluel en une vingtaine de minutes par la D1084.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="tel:0635464924" class="btn-accent text-base py-4 px-8">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Appeler maintenant
        </a>
        <a href="/contact/" class="btn-ghost text-base py-4 px-8">
          Devis gratuit en ligne
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 overflow-hidden -mb-px" style="line-height:0"><svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-[40px] sm:h-[50px] lg:h-[60px]"><polygon points="0,60 1440,20 1440,60" fill="#F8FAFC"/></svg></div>
  </section>

  <!-- INTRODUCTION -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-3xl mx-auto px-4 lg:px-6 reveal">
      <p class="text-slate-600 leading-relaxed mb-6">
        Chef-lieu de canton, Montluel est une ville historique de près de 7 000 habitants, avec un centre ancien dense et des zones résidentielles plus récentes en périphérie.
      </p>
      <p class="text-slate-600 leading-relaxed mb-6">
        Le patrimoine bâti de Montluel est particulier : le centre-ville abrite des bâtisses anciennes dont les réseaux de plomberie datent parfois de plusieurs décennies. Ces installations nécessitent un savoir-faire spécifique pour les mises en conformité, la recherche de fuites dans des murs épais ou le remplacement de canalisations en plomb. Dans les quartiers plus récents et les lotissements, les demandes concernent davantage l'optimisation énergétique : remplacement de chaudières anciennes par des modèles à condensation, installation de pompes à chaleur.
      </p>
      <p class="text-slate-600 leading-relaxed">
        Nous travaillons avec les particuliers comme avec les commerces du centre-ville de Montluel. Chaque intervention commence par un diagnostic précis et un devis clair. Appelez le 06 35 46 49 24 pour prendre rendez-vous.
      </p>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 lg:px-6">
      <div class="text-center mb-12 reveal">
        <span class="section-label">Nos interventions</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Services disponibles à Montluel</h2>
        <p class="text-slate-500 max-w-xl mx-auto">Nos techniciens interviennent à Montluel pour l'ensemble de vos besoins.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
        {services.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- PROXIMITÉ -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-3xl mx-auto px-4 lg:px-6 reveal">
      <div class="text-center mb-8">
        <span class="section-label">Proximité</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900">Votre plombier à 20 minutes de Montluel</h2>
      </div>
      <p class="text-slate-600 leading-relaxed text-center">
        Notre implantation à Neyron nous place à 12 km de Montluel, un trajet direct par la Côtière. Ce positionnement géographique nous permet de couvrir efficacement Montluel et les communes voisines : Dagneux, Balan, La Boisse. Pour les urgences, nous faisons notre maximum pour être sur place dans l'heure.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <FaqSection questions={faq} title="Questions fréquentes - Montluel" />

  <!-- CTA -->
  <CtaBanner title="Besoin d'un plombier à Montluel ?" subtitle="Devis gratuit, intervention rapide depuis Neyron." />

</Base>
