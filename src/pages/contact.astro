---
import Base from '../layouts/Base.astro';
import CtaBanner from '../components/CtaBanner.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Contact', url: '/contact/' },
];

const jsonLd = {
  '@type': 'ContactPage',
  name: 'Contactez RM Plombier SARL',
  description: 'Demandez un devis gratuit ou contactez RM Plombier SARL pour toute intervention plomberie, chauffage ou climatisation dans l\'Ain et le Rhône.',
  url: 'https://rm-plombier.fr/contact/',
};
---

<Base
  title="Contact et devis gratuit | RM Plombier SARL"
  description="Demandez un devis gratuit ou contactez RM Plombier SARL pour toute intervention plomberie, chauffage ou climatisation dans l'Ain et le Rhône."
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="py-10 lg:py-14 bg-surface">
    <div class="max-w-4xl mx-auto px-4 lg:px-6 text-center">
      <span class="section-label">Contact</span>
      <h1 class="text-2xl lg:text-4xl font-extrabold text-primary-dark mt-2 mb-4">Contactez-nous</h1>
      <p class="text-slate-600 text-lg">Devis gratuit, réponse rapide. Décrivez votre besoin, nous vous recontactons.</p>
    </div>
  </section>

  <!-- Contact grid -->
  <section class="py-12 lg:py-16">
    <div class="max-w-5xl mx-auto px-4 lg:px-6 grid lg:grid-cols-5 gap-10">

      <!-- Formulaire -->
      <div class="lg:col-span-3">
        <form class="space-y-5" name="contact" method="POST" data-netlify="true">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="nom" class="block text-sm font-semibold text-slate-700 mb-1.5">Nom complet *</label>
              <input type="text" id="nom" name="nom" required autocomplete="name" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition text-sm" placeholder="Votre nom" />
            </div>
            <div>
              <label for="telephone" class="block text-sm font-semibold text-slate-700 mb-1.5">Téléphone *</label>
              <input type="tel" id="telephone" name="telephone" required autocomplete="tel" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition text-sm" placeholder="06 XX XX XX XX" />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5">Email</label>
            <input type="email" id="email" name="email" autocomplete="email" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition text-sm" placeholder="votre@email.com" />
          </div>

          <div>
            <label for="type" class="block text-sm font-semibold text-slate-700 mb-1.5">Type de demande *</label>
            <select id="type" name="type" required class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition text-sm bg-white">
              <option value="">Sélectionnez...</option>
              <option value="urgence">Dépannage urgence</option>
              <option value="devis">Demande de devis</option>
              <option value="chaudiere">Installation / entretien chaudière</option>
              <option value="climatisation">Climatisation / PAC</option>
              <option value="salle-de-bain">Rénovation salle de bain</option>
              <option value="fuite">Détection / réparation de fuite</option>
              <option value="autre">Autre</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-slate-700 mb-1.5">Message *</label>
            <textarea id="message" name="message" required rows="5" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition text-sm resize-y" placeholder="Décrivez votre besoin : type de travaux, urgence, commune..."></textarea>
          </div>

          <button type="submit" class="btn-primary w-full sm:w-auto">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Envoyer ma demande
          </button>
        </form>
      </div>

      <!-- Infos contact -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Téléphone -->
        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-primary-dark mb-1">Téléphone</h3>
              <a href="tel:0635464924" class="text-primary font-semibold hover:underline">06 35 46 49 24</a>
              <p class="text-sm text-slate-500 mt-1">Urgences 7j/7</p>
            </div>
          </div>
        </div>

        <!-- Horaires -->
        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-primary-dark mb-1">Horaires</h3>
              <p class="text-sm text-slate-600">Lundi - Samedi : 7h - 20h</p>
              <p class="text-sm text-slate-500">Urgences : 7j/7 sur appel</p>
            </div>
          </div>
        </div>

        <!-- Adresse -->
        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-primary-dark mb-1">Adresse</h3>
              <p class="text-sm text-slate-600">01700 Neyron</p>
              <p class="text-sm text-slate-500 mt-1">Ain, France</p>
            </div>
          </div>
        </div>

        <!-- Zone -->
        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-primary-dark mb-1">Zone d'intervention</h3>
              <p class="text-sm text-slate-600">Neyron, Miribel, Rillieux-la-Pape, Beynost, Montluel, Caluire-et-Cuire</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner title="Urgence plomberie ?" subtitle="Nous intervenons 7j/7 dans l'Ain et le nord du Rhône." />
</Base>
