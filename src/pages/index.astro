---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ReviewCard from '../components/ReviewCard.astro';
import FaqSection from '../components/FaqSection.astro';
import CtaBanner from '../components/CtaBanner.astro';

const jsonLd = [
  {
    '@type': 'Plumber',
    '@id': 'https://rm-plombier.fr/#business',
    name: 'RM Plombier SARL',
    url: 'https://rm-plombier.fr/',
    telephone: '+33635464924',
    description: 'Plombier à Neyron et dans l\'Ain. Dépannage, installation sanitaire, débouchage. Intervention rapide 7j/7.',
    address: { '@type': 'PostalAddress', addressLocality: 'Neyron', postalCode: '01700', addressRegion: 'Ain', addressCountry: 'FR' },
    geo: { '@type': 'GeoCoordinates', latitude: 45.8389, longitude: 4.9547 },
    areaServed: [
      { '@type': 'City', name: 'Neyron' },
      { '@type': 'City', name: 'Miribel' },
      { '@type': 'City', name: 'Rillieux-la-Pape' },
      { '@type': 'City', name: 'Beynost' },
      { '@type': 'City', name: 'Montluel' },
      { '@type': 'City', name: 'Caluire-et-Cuire' },
    ],
    openingHoursSpecification: [
      { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '07:00', closes: '20:00' },
    ],
    aggregateRating: { '@type': 'AggregateRating', ratingValue: '5', reviewCount: '54', bestRating: '5' },
    priceRange: '€€',
  },
  { '@type': 'WebSite', '@id': 'https://rm-plombier.fr/#website', url: 'https://rm-plombier.fr/', name: 'RM Plombier SARL' },
];

const services = [
  { title: 'Dépannage plomberie urgence', description: 'Une fuite d\'eau, un WC bouché, un ballon d\'eau chaude en panne ? Nous intervenons en urgence 7j/7 dans l\'Ain et le Rhône.', href: '/services/depannage-plomberie/', icon: 'wrench', tags: ['Fuite d\'eau', 'WC bouché', 'Chauffe-eau'], image: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/robinet-noir-inox-square.png' },
  { title: 'Installation chaudière', description: 'Nous installons et remplaçons tous types de chaudières : gaz, condensation, basse température. Conseil adapté à votre logement.', href: '/services/installation-chaudiere/', icon: 'fire', tags: ['Gaz', 'Condensation', 'PAC'], image: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/radiateur-salon-landscape.png' },
  { title: 'Climatisation et PAC', description: 'Climatisations réversibles et pompes à chaleur air-eau adaptées aux maisons et appartements de la région.', href: '/services/climatisation-pompe-a-chaleur/', icon: 'snowflake', tags: ['Clim réversible', 'PAC air-eau'], image: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/pac-buanderie-gris-landscape.png' },
  { title: 'Rénovation salle de bain', description: 'Rénovation complète : dépose, plomberie, pose de douche italienne, baignoire, robinetterie et raccordements.', href: '/services/renovation-salle-de-bain/', icon: 'home', tags: ['Douche italienne', 'Baignoire'], image: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/douche-italienne-beton-landscape.png' },
  { title: 'Détection de fuites', description: 'Localisation précise des fuites grâce à des méthodes non destructives, puis réparation dans la foulée.', href: '/services/detection-reparation-fuites/', icon: 'search', tags: ['Non destructif', 'Caméra thermique'], image: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/evier-inox-cuisine-landscape.png' },
];

const reviews = [
  { text: 'Intervention rapide suite à une fuite sous évier. Très professionnel, propre et tarif honnête. Je recommande vivement RM Plombier.', author: 'Marie C.', date: 'il y a 2 semaines' },
  { text: 'Installation complète de notre salle de bain. Travail soigné, respect des délais et du budget. L\'équipe est sérieuse et à l\'écoute.', author: 'Thomas L.', date: 'il y a 1 mois' },
  { text: 'Remplacement de chaudière réalisé en une journée. Tout fonctionne parfaitement, et le technicien nous a bien expliqué le fonctionnement.', author: 'Sophie D.', date: 'il y a 3 semaines' },
  { text: 'Débouchage de canalisation un dimanche matin. Ils ont répondu au téléphone et sont venus en 45 minutes. Prix correct.', author: 'Pierre M.', date: 'il y a 1 mois' },
  { text: 'Détection d\'une fuite cachée dans notre mur sans rien casser. Réparation faite dans la foulée. Très compétent et rassurant.', author: 'Nathalie B.', date: 'il y a 2 mois' },
  { text: 'Pose d\'une climatisation réversible chez nous à Miribel. Installation propre, explications claires. Très satisfaits du résultat.', author: 'Laurent G.', date: 'il y a 3 semaines' },
];

const zones = [
  { name: 'Miribel', href: '/plombier-miribel/', distance: '3 km' },
  { name: 'Rillieux-la-Pape', href: '/plombier-rillieux-la-pape/', distance: '5 km' },
  { name: 'Beynost', href: '/plombier-beynost/', distance: '7 km' },
  { name: 'Montluel', href: '/plombier-montluel/', distance: '12 km' },
  { name: 'Caluire-et-Cuire', href: '/plombier-caluire-et-cuire/', distance: '8 km' },
];

const galleryImages = [
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/douche-italienne-beton-landscape.png', alt: 'Douche italienne en béton ciré' },
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/baignoire-ilot-parquet-square.png', alt: 'Baignoire îlot sur parquet' },
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/wc-suspendu-anthracite-landscape.png', alt: 'WC suspendu anthracite' },
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/double-vasque-zellige-square.png', alt: 'Double vasque avec zellige' },
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/colonne-douche-beton-landscape.png', alt: 'Colonne de douche en béton' },
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/robinet-dore-cuisine-landscape.png', alt: 'Robinet doré cuisine' },
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/baignoire-encastree-doree-square.png', alt: 'Baignoire encastrée avec robinetterie dorée' },
  { src: 'https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/seche-serviettes-taupe-square.png', alt: 'Sèche-serviettes taupe' },
];

const faq = [
  { q: 'Intervenez-vous en urgence la nuit ?', a: 'Nous intervenons 7j/7 de 7h à 21h. Pour les urgences en soirée, appelez le 06 35 46 49 24, nous évaluons la situation et intervenons si possible ou dès le lendemain matin.' },
  { q: 'Le devis est-il gratuit ?', a: 'Oui, le devis est gratuit et sans engagement pour tous les projets d\'installation ou de rénovation. Pour un dépannage, le diagnostic sur place est inclus dans l\'intervention.' },
  { q: 'Quelle est votre zone d\'intervention ?', a: 'Nous intervenons à Neyron et dans un rayon de 30 km : Miribel, Rillieux-la-Pape, Beynost, Montluel, Caluire-et-Cuire et toutes les communes de l\'Ain et du nord Rhône.' },
  { q: 'Êtes-vous assuré pour les travaux ?', a: 'Oui, RM Plombier SARL dispose d\'une garantie décennale et d\'une assurance responsabilité civile professionnelle couvrant l\'ensemble de nos interventions.' },
  { q: 'Quels modes de paiement acceptez-vous ?', a: 'Nous acceptons les paiements par carte bancaire, chèque, virement et espèces. Nous pouvons également proposer un échelonnement pour les travaux importants.' },
];
---

<Base
  title="Plombier Neyron (01700) | RM Plombier SARL - Ain et Rhône"
  description="RM Plombier SARL à Neyron : dépannage 7j/7, chauffage, climatisation et rénovation. 5/5 sur Google (54 avis). Devis gratuit au 06 35 46 49 24."
  jsonLd={jsonLd}
>

  <!-- HERO SPLIT -->
  <section class="min-h-[100dvh] bg-gradient-to-br from-primary-dark via-primary to-primary-light relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]">
      <svg width="100%" height="100%"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
    </div>
    <div class="max-w-6xl mx-auto px-4 lg:px-6 min-h-[100dvh] flex items-center relative z-10">
      <div class="w-full py-20 lg:py-0 grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <!-- Texte -->
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 mb-6 backdrop-blur-sm">
            <div class="w-2 h-2 bg-accent rounded-full animate-pulse"></div>
            <span class="text-sm font-medium text-white/90">Disponible maintenant. Neyron et alentours</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight text-white mb-4 max-w-3xl">
            Plombier à Neyron, intervention rapide dans <span class="text-accent">l'Ain et le Rhône</span>
          </h1>
          <p class="text-lg text-white/70 mb-8 leading-relaxed max-w-2xl">
            Dépannage, installation, rénovation. RM Plombier SARL intervient 7j/7 chez les particuliers et professionnels de Neyron à Caluire-et-Cuire.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-12">
            <a href="tel:0635464924" class="btn-accent text-base py-4 px-8">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Appelez le 06 35 46 49 24
            </a>
            <a href="/contact/" class="btn-ghost text-base py-4 px-8">
              Demander un devis gratuit
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="flex flex-wrap gap-4">
            <div class="flex items-center gap-3 bg-white/10 border border-white/20 rounded-xl px-4 py-3 backdrop-blur-sm">
              <div class="w-10 h-10 bg-accent/20 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg></div>
              <div><div class="text-xl font-bold text-white">5/5</div><div class="text-xs text-white/60"><span class="whitespace-nowrap">54 avis</span> Google</div></div>
            </div>
            <div class="flex items-center gap-3 bg-white/10 border border-white/20 rounded-xl px-4 py-3 backdrop-blur-sm">
              <div class="w-10 h-10 bg-success/20 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div>
              <div><div class="text-xl font-bold text-white">Garantie</div><div class="text-xs text-white/60">Décennale</div></div>
            </div>
            <div class="flex items-center gap-3 bg-white/10 border border-white/20 rounded-xl px-4 py-3 backdrop-blur-sm">
              <div class="w-10 h-10 bg-primary-light/30 rounded-lg flex items-center justify-center"><svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
              <div><div class="text-xl font-bold text-white">7j/7</div><div class="text-xs text-white/60">Urgences</div></div>
            </div>
          </div>
        </div>
        <!-- Image hero (visible desktop uniquement) -->
        <div class="hidden lg:block">
          <img
            src="https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/plombier-evier-cuisine-square.png"
            alt="Plombier RM Plombier intervenant sur un évier de cuisine"
            class="rounded-2xl shadow-2xl w-full aspect-square object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0"><svg viewBox="0 0 1440 80" fill="none"><path d="M0 80H1440V40C1200 0 960 80 720 40C480 0 240 80 0 40V80Z" fill="#F8FAFC"/></svg></div>
  </section>

  <!-- POURQUOI RM PLOMBIER -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-6xl mx-auto px-4 lg:px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center reveal">
        <div>
          <span class="section-label">Notre engagement</span>
          <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mt-2 mb-6">Pourquoi choisir RM Plombier</h2>
          <p class="text-slate-500 leading-relaxed mb-6">Basée à Neyron dans l'Ain, RM Plombier SARL est une entreprise de plomberie, chauffage et climatisation qui intervient dans tout le nord de l'agglomération lyonnaise. Notre zone couvre l'Ain et le Rhône, de Miribel à Caluire-et-Cuire, en passant par Rillieux-la-Pape, Beynost et Montluel.</p>
          <p class="text-slate-500 leading-relaxed mb-8">Nos clients nous font confiance pour trois raisons simples. D'abord, la réactivité : nous intervenons en urgence 7 jours sur 7. Ensuite, la transparence : chaque intervention commence par un diagnostic clair et un devis gratuit. Enfin, la qualité : nos techniciens sont qualifiés pour tous types de travaux.</p>
          <div class="space-y-4">
            <div class="flex gap-4"><div class="w-12 h-12 bg-surface-alt rounded-xl flex items-center justify-center flex-shrink-0"><svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div><div><h3 class="font-bold text-slate-900 mb-1">Intervention rapide garantie</h3><p class="text-sm text-slate-500">Moins de 2h pour les urgences à Neyron et 20 km alentours.</p></div></div>
            <div class="flex gap-4"><div class="w-12 h-12 bg-surface-alt rounded-xl flex items-center justify-center flex-shrink-0"><svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><div><h3 class="font-bold text-slate-900 mb-1">Devis gratuit et transparent</h3><p class="text-sm text-slate-500">Aucune surprise sur la facture. Devis validé par écrit avant travaux.</p></div></div>
            <div class="flex gap-4"><div class="w-12 h-12 bg-success/10 rounded-xl flex items-center justify-center flex-shrink-0"><svg class="w-6 h-6 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div><div><h3 class="font-bold text-slate-900 mb-1">Garantie décennale</h3><p class="text-sm text-slate-500">Tous nos travaux couverts par notre assurance décennale et RC pro.</p></div></div>
          </div>
        </div>
        <div class="relative">
          <img
            src="https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/library-images/plomberie/plombier-ballon-buanderie-square.png"
            alt="Plombier RM Plombier travaillant sur un ballon d'eau chaude en buanderie"
            class="rounded-2xl shadow-lg w-full aspect-[4/3] object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 lg:px-6">
      <div class="text-center mb-12 reveal">
        <span class="section-label">Nos interventions</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Tous vos besoins en plomberie</h2>
        <p class="text-slate-500 max-w-xl mx-auto">De la petite réparation à la rénovation complète, RM Plombier intervient sur l'ensemble de vos installations.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
        {services.map(s => (
          <div class="card group overflow-hidden">
            <div class="aspect-[16/10] overflow-hidden rounded-xl mb-5 -mx-1 -mt-1">
              <img src={s.image} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{s.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed mb-4">{s.description}</p>
            {s.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-5">
                {s.tags.map(tag => (
                  <span class="bg-surface-alt text-primary text-xs font-medium px-2.5 py-1 rounded-full">{tag}</span>
                ))}
              </div>
            )}
            <a href={s.href} class="flex items-center gap-1.5 text-primary font-semibold text-sm hover:gap-3 transition-all duration-200">
              En savoir plus
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REALISATIONS / GALLERY -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-6xl mx-auto px-4 lg:px-6">
      <div class="text-center mb-12 reveal">
        <span class="section-label">Nos réalisations</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Un aperçu de nos travaux</h2>
        <p class="text-slate-500 max-w-xl mx-auto">Salles de bain, plomberie, installations sanitaires. Quelques exemples de réalisations par notre équipe.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 reveal-stagger" id="gallery-grid">
        {galleryImages.map((img, i) => (
          <button
            class="gallery-item overflow-hidden rounded-xl cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary"
            data-index={i}
            data-src={img.src}
            data-alt={img.alt}
            type="button"
          >
            <img src={img.src} alt={img.alt} class="w-full aspect-[4/3] object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center" role="dialog" aria-modal="true" aria-label="Galerie photos">
    <button id="lightbox-close" class="absolute top-4 right-4 text-white/80 hover:text-white z-10 p-2" aria-label="Fermer">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white z-10 p-2" aria-label="Image précédente">
      <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white z-10 p-2" aria-label="Image suivante">
      <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg" />
  </div>

  <!-- AVIS -->
  <section class="py-16 lg:py-24 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 mb-8 reveal">
      <span class="section-label">Avis clients</span>
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900">Ce que disent nos clients</h2>
    </div>
    <div class="overflow-hidden">
      <div class="reviews-track">
        {[...reviews, ...reviews].map(r => <ReviewCard {...r} />)}
      </div>
    </div>
  </section>

  <!-- ZONE D'INTERVENTION - CARTE LEAFLET -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-6xl mx-auto px-4 lg:px-6">
      <div class="text-center mb-12 reveal">
        <span class="section-label">Zone d'intervention</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4">Plombier proche de chez vous</h2>
        <p class="text-slate-500 max-w-xl mx-auto">Basés à Neyron, nous intervenons dans l'Ain et le nord du Rhône dans un rayon de 20 km.</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-8 items-start reveal">
        <!-- Carte Leaflet -->
        <div class="w-full">
          <div id="map" class="w-full aspect-square sm:aspect-[4/3] rounded-2xl shadow-lg border border-slate-200 z-0"></div>
        </div>
        <!-- Texte + liens communes -->
        <div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">Intervention rapide dans l'Ain et le Rhône</h3>
          <p class="text-slate-500 leading-relaxed mb-6">Notre équipe est basée à Neyron (01700) et couvre toutes les communes dans un rayon de 20 km. Temps d'intervention moyen : 30 à 45 minutes selon votre localisation.</p>
          <div class="space-y-3">
            {zones.map(z => (
              <a href={z.href} class="flex items-center gap-3 bg-white rounded-xl p-4 border border-slate-100 hover:border-primary/30 hover:shadow-sm transition-all group">
                <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div class="flex-1">
                  <div class="font-bold text-slate-900 text-sm group-hover:text-primary transition-colors">{z.name}</div>
                  <div class="text-xs text-slate-400">{z.distance} de Neyron</div>
                </div>
                <svg class="w-4 h-4 text-slate-300 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- FAQ -->
  <FaqSection questions={faq} />

  <!-- CTA -->
  <CtaBanner />

  <!-- Leaflet JS + Lightbox JS -->
  <script is:inline>
    // ---- LEAFLET MAP ----
    (function() {
      var script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.onload = function() {
        var map = L.map('map', { scrollWheelZoom: false }).setView([45.8389, 4.9547], 11);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        // Cercle 20km
        L.circle([45.8389, 4.9547], {
          radius: 20000,
          color: '#1B4F8A',
          fillColor: '#1B4F8A',
          fillOpacity: 0.1,
          weight: 2
        }).addTo(map);

        // Marqueur Neyron
        L.marker([45.8389, 4.9547]).addTo(map).bindPopup('<strong>RM Plombier SARL</strong><br>Neyron (01700)');

        // Communes
        var communes = [
          { name: 'Miribel', lat: 45.8250, lng: 4.9533 },
          { name: 'Rillieux-la-Pape', lat: 45.8131, lng: 4.8984 },
          { name: 'Beynost', lat: 45.8367, lng: 5.0283 },
          { name: 'Montluel', lat: 45.8542, lng: 5.0567 },
          { name: 'Caluire-et-Cuire', lat: 45.7950, lng: 4.8450 },
        ];
        communes.forEach(function(c) {
          L.circleMarker([c.lat, c.lng], {
            radius: 6, color: '#1B4F8A', fillColor: '#1B4F8A', fillOpacity: 0.8, weight: 2
          }).addTo(map).bindPopup(c.name);
        });
      };
      document.head.appendChild(script);
    })();

    // ---- LIGHTBOX ----
    (function() {
      var lightbox = document.getElementById('lightbox');
      var lbImg = document.getElementById('lightbox-img');
      var items = document.querySelectorAll('.gallery-item');
      var currentIndex = 0;
      var images = [];

      items.forEach(function(item, i) {
        images.push({ src: item.dataset.src, alt: item.dataset.alt });
        item.addEventListener('click', function() {
          currentIndex = i;
          showImage();
          lightbox.classList.remove('hidden');
          lightbox.classList.add('flex');
        });
      });

      function showImage() {
        lbImg.src = images[currentIndex].src;
        lbImg.alt = images[currentIndex].alt;
      }

      document.getElementById('lightbox-close').addEventListener('click', closeLb);
      lightbox.addEventListener('click', function(e) {
        if (e.target === lightbox) closeLb();
      });

      function closeLb() {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
      }

      document.getElementById('lightbox-prev').addEventListener('click', function(e) {
        e.stopPropagation();
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        showImage();
      });

      document.getElementById('lightbox-next').addEventListener('click', function(e) {
        e.stopPropagation();
        currentIndex = (currentIndex + 1) % images.length;
        showImage();
      });

      document.addEventListener('keydown', function(e) {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLb();
        if (e.key === 'ArrowLeft') { currentIndex = (currentIndex - 1 + images.length) % images.length; showImage(); }
        if (e.key === 'ArrowRight') { currentIndex = (currentIndex + 1) % images.length; showImage(); }
      });
    })();
  </script>

</Base>
