>
  <!-- Hero compact -->
  <section class="py-10 lg:py-14 bg-surface">
    <div class="max-w-3xl mx-auto px-4 lg:px-6">
      <span class="section-label">Rénovation</span>
      <h1 class="text-2xl lg:text-4xl font-extrabold text-primary-dark mt-2 mb-4">Rénovation salle de bain : budget, étapes et conseils d'un pro</h1>
      <div class="flex items-center gap-3 text-sm text-slate-500">
        <time datetime="2026-03-01">1 mars 2026</time>
        <span class="text-slate-300">|</span>
        <span>5 min de lecture</span>
      </div>
    </div>
