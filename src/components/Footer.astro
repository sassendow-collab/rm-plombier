---
const services = [
  { name: 'Dépannage plomberie urgence', href: '/services/depannage-plomberie/' },
  { name: 'Installation chaudière', href: '/services/installation-chaudiere/' },
  { name: 'Climatisation et pompe à chaleur', href: '/services/climatisation-pompe-a-chaleur/' },
  { name: 'Rénovation salle de bain', href: '/services/renovation-salle-de-bain/' },
  { name: 'Détection et réparation de fuites', href: '/services/detection-reparation-fuites/' },
];
const zones = [
  { name: 'Neyron (siège)', href: '/' },
  { name: 'Miribel', href: '/plombier-miribel/' },
  { name: 'Rillieux-la-Pape', href: '/plombier-rillieux-la-pape/' },
  { name: 'Beynost', href: '/plombier-beynost/' },
  { name: 'Montluel', href: '/plombier-montluel/' },
  { name: 'Caluire-et-Cuire', href: '/plombier-caluire-et-cuire/' },
];
const trustBadges = [
  { icon: 'shield', title: 'Garantie décennale', sub: 'Tous travaux couverts' },
  { icon: 'clock', title: 'Urgences 7j/7', sub: 'Intervention rapide' },
  { icon: 'star', title: '5/5 sur Google', sub: '54 avis vérifiés' },
  { icon: 'check', title: 'Devis gratuit', sub: 'Sans engagement' },
];
---

<footer class="bg-primary-dark text-white">
  <!-- Trust badges -->
  <div class="border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {trustBadges.map(badge => (
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-accent/20 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                {badge.icon === 'shield' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>}
                {badge.icon === 'clock' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>}
                {badge.icon === 'star' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>}
                {badge.icon === 'check' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>}
              </svg>
            </div>
            <div>
              <div class="font-semibold text-sm">{badge.title}</div>
              <div class="text-xs text-white/50">{badge.sub}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="max-w-6xl mx-auto px-4 lg:px-6 py-12">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Col 1 : Identity -->
      <div class="col-span-2 lg:col-span-1">
        <div class="mb-4">
          <img src="https://emqtwhjbqlgyjfopbkqg.supabase.co/storage/v1/object/public/logos/26a2cf40-82ab-4ea6-917a-61f61bfdf36b.png" alt="RM Plombier SARL" class="h-12 max-w-[160px] object-contain brightness-0 invert" />
        </div>
        <p class="text-sm text-white/60 leading-relaxed mb-4">
          Artisan plombier chauffagiste basé à Neyron. Interventions dans l'Ain et le Rhône depuis 2009.
        </p>
        <a href="tel:0635464924" class="inline-flex items-center gap-2 bg-accent text-primary-dark px-4 py-2.5 rounded-lg font-bold text-sm hover:bg-accent-dark transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          06 35 46 49 24
        </a>
      </div>

      <!-- Col 2 : Services -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-widest text-white/40 mb-4">Services</h4>
        <ul class="space-y-2.5">
          {services.map(s => (
            <li><a href={s.href} class="text-sm text-white/70 hover:text-white transition-colors">{s.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3 : Zones -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-widest text-white/40 mb-4">Zones d'intervention</h4>
        <ul class="space-y-2.5">
          {zones.map(z => (
            <li><a href={z.href} class="text-sm text-white/70 hover:text-white transition-colors">{z.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 4 : Infos -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-widest text-white/40 mb-4">Infos pratiques</h4>
        <ul class="space-y-2.5">
          <li><a href="/blog/" class="text-sm text-white/70 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/contact/" class="text-sm text-white/70 hover:text-white transition-colors">Contact et devis</a></li>
          <li><a href="/mentions-legales/" class="text-sm text-white/70 hover:text-white transition-colors">Mentions légales</a></li>
          <li><a href="/politique-confidentialite/" class="text-sm text-white/70 hover:text-white transition-colors">Politique de confidentialité</a></li>
        </ul>
        <div class="mt-6 bg-white/5 rounded-xl p-3">
          <div class="text-xs font-semibold text-white/40 uppercase tracking-wide mb-2">Horaires</div>
          <div class="text-sm text-white/70">Lun-Sam : 7h - 20h</div>
          <div class="text-sm text-success font-medium">Urgences : 7j/7</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 lg:px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="text-xs text-white/40">&copy; 2026 RM Plombier SARL. Tous droits réservés.</p>
      <p class="text-xs text-white/30">Site par <a href="https://sendow.ai" class="hover:text-white/60 transition-colors" target="_blank" rel="noopener">Sendow</a></p>
    </div>
  </div>
</footer>
