---
const services = [
  { name: 'Dépannage urgence', href: '/services/depannage-plomberie/' },
  { name: 'Installation chaudière', href: '/services/installation-chaudiere/' },
  { name: 'Climatisation / PAC', href: '/services/climatisation-pompe-a-chaleur/' },
  { name: 'Rénovation salle de bain', href: '/services/renovation-salle-de-bain/' },
  { name: 'Détection de fuites', href: '/services/detection-reparation-fuites/' },
];
const zones = [
  { name: 'Plombier Miribel', href: '/plombier-miribel/' },
  { name: 'Plombier Rillieux-la-Pape', href: '/plombier-rillieux-la-pape/' },
  { name: 'Plombier Beynost', href: '/plombier-beynost/' },
  { name: 'Plombier Montluel', href: '/plombier-montluel/' },
  { name: 'Plombier Caluire-et-Cuire', href: '/plombier-caluire-et-cuire/' },
];
---

<!-- Topbar desktop -->
<div class="hidden lg:block bg-primary-dark text-white text-sm py-2">
  <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
    <div class="flex items-center gap-6">
      <a href="tel:0635464924" class="flex items-center gap-2 hover:text-accent transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        06 35 46 49 24
      </a>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Lun-Sam 7h-20h | Urgences 7j/7
      </span>
    </div>
    <div class="flex items-center gap-3">
      <span class="bg-accent text-primary-dark text-xs font-bold px-3 py-1 rounded-full">Urgence 24h/24</span>
    </div>
  </div>
</div>

<!-- Nav principale -->
<header id="main-header" class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-200 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 lg:px-6 h-16 lg:h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3" aria-label="RM Plombier SARL - Accueil">
      <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
      </div>
      <div>
        <div class="font-heading font-extrabold text-primary-dark text-lg leading-none">RM Plombier</div>
        <div class="text-xs text-slate-500 font-medium">Neyron - Ain (01700)</div>
      </div>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Navigation principale">
      <a href="/" class="nav-link text-slate-900 font-medium text-sm">Accueil</a>
      <div class="relative group">
        <button class="nav-link text-slate-900 font-medium text-sm flex items-center gap-1">
          Services
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-white rounded-xl shadow-xl border border-slate-200 py-2 min-w-[220px]">
            {services.map(s => (
              <a href={s.href} class="block px-4 py-2 text-sm text-slate-700 hover:bg-surface-alt hover:text-primary transition-colors">{s.name}</a>
            ))}
          </div>
        </div>
      </div>
      <div class="relative group">
        <button class="nav-link text-slate-900 font-medium text-sm flex items-center gap-1">
          Zones
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-white rounded-xl shadow-xl border border-slate-200 py-2 min-w-[240px]">
            {zones.map(z => (
              <a href={z.href} class="block px-4 py-2 text-sm text-slate-700 hover:bg-surface-alt hover:text-primary transition-colors">{z.name}</a>
            ))}
          </div>
        </div>
      </div>
      <a href="/blog/" class="nav-link text-slate-900 font-medium text-sm">Blog</a>
      <a href="/contact/" class="nav-link text-slate-900 font-medium text-sm">Contact</a>
    </nav>

    <!-- CTA desktop -->
    <a href="tel:0635464924" class="hidden lg:flex btn-primary text-xs">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      Appeler maintenant
    </a>

    <!-- Burger mobile -->
    <button id="burger" class="lg:hidden p-2 rounded-lg hover:bg-surface-alt" aria-expanded="false" aria-controls="mobile-menu" aria-label="Ouvrir le menu">
      <svg class="w-6 h-6 text-primary-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-200 bg-white">
    <nav class="max-w-6xl mx-auto px-4 py-4 space-y-1">
      <a href="/" class="block py-2 text-sm font-medium text-slate-900">Accueil</a>
      <div class="py-2">
        <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Services</div>
        {services.map(s => (
          <a href={s.href} class="block py-1.5 pl-3 text-sm text-slate-600 hover:text-primary">{s.name}</a>
        ))}
      </div>
      <div class="py-2">
        <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Zones</div>
        {zones.map(z => (
          <a href={z.href} class="block py-1.5 pl-3 text-sm text-slate-600 hover:text-primary">{z.name}</a>
        ))}
      </div>
      <a href="/blog/" class="block py-2 text-sm font-medium text-slate-900">Blog</a>
      <a href="/contact/" class="block py-2 text-sm font-medium text-slate-900">Contact</a>
      <a href="tel:0635464924" class="btn-accent w-full mt-3 text-center">
        Urgence : 06 35 46 49 24
      </a>
    </nav>
  </div>
</header>
