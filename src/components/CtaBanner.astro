---
interface Props {
  title?: string;
  subtitle?: string;
}
const { title = 'Besoin d\'un plombier ?', subtitle = 'Devis gratuit, intervention rapide dans l\'Ain et le Rhône.' } = Astro.props;
---

<section class="py-12 lg:py-16 bg-gradient-to-r from-primary-dark to-primary">
  <div class="max-w-4xl mx-auto px-4 lg:px-6 text-center text-white">
    <h2 class="text-2xl lg:text-3xl font-bold mb-3">{title}</h2>
    <p class="text-white/70 mb-6">{subtitle}</p>
    <div class="flex flex-col sm:flex-row justify-center gap-3">
      <a href="tel:0635464924" class="btn-accent">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Appelez le 06 35 46 49 24
      </a>
      <a href="/contact/" class="btn-ghost">Demander un devis gratuit</a>
    </div>
  </div>
</section>
